{
  "name": "@frameboard/core",
  "version": "0.1.0",
  "description": "Framework-agnostic registry, device, and utility types for FrameBoard.",
  "keywords": [
    "frameboard",
    "screen-states",
    "fixtures",
    "design-review",
    "ui-review"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/frameboard/frameboard.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/frameboard/frameboard#readme",
  "bugs": {
    "url": "https://github.com/frameboard/frameboard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --dir ../.. build:packages",
    "clean": "node ../../scripts/clean.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run ../../packages/core/tests"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
