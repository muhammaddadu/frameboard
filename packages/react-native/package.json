{
  "name": "@frameboard/react-native",
  "version": "0.1.0",
  "description": "React Native and Expo renderer for FrameBoard.",
  "keywords": [
    "frameboard",
    "react-native",
    "expo",
    "screen-states",
    "fixtures",
    "design-review"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammaddadu/frameboard.git",
    "directory": "packages/react-native"
  },
  "homepage": "https://muhammaddadu.github.io/frameboard/",
  "bugs": {
    "url": "https://github.com/muhammaddadu/frameboard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --dir ../.. build:packages",
    "clean": "node ../../scripts/clean.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run ../../packages/react-native/tests"
  },
  "dependencies": {
    "@frameboard/core": "workspace:*",
    "html-to-image": "^1.11.13",
    "lucide-react-native": "^0.468.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-svg": ">=15"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-native": "^0.82.1",
    "typescript": "^5.9.2"
  }
}
