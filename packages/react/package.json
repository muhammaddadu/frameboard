{
  "name": "@frameboard/react",
  "version": "0.0.0",
  "description": "DOM React renderer for FrameBoard.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --test tests/**/*.test.mjs"
  },
  "dependencies": {
    "@frameboard/core": "workspace:*",
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.2"
  }
}
