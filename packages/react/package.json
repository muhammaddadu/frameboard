{
  "name": "@frameboard/react",
  "version": "0.1.0",
  "description": "DOM React renderer for FrameBoard.",
  "keywords": [
    "frameboard",
    "react",
    "screen-states",
    "fixtures",
    "design-review",
    "ui-review"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/frameboard/frameboard.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/frameboard/frameboard#readme",
  "bugs": {
    "url": "https://github.com/frameboard/frameboard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "pnpm --dir ../.. build:packages",
    "clean": "node ../../scripts/clean.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run ../../packages/react/tests"
  },
  "dependencies": {
    "@frameboard/core": "workspace:*",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.2"
  }
}
